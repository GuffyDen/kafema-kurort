# Tablo platform / tenant integration.
# IIKO_APP_ID and IIKO_CLIENT_SECRET belong to the Tablo app.
# IIKO_API_KEY and IIKO_TERMINAL_GROUP_ID belong to a specific tenant.

IIKO_API_BASE_URL=https://api-ru.iiko.services/api/1/
IIKO_API_KEY=
IIKO_APP_ID=
IIKO_CLIENT_SECRET=
IIKO_TERMINAL_GROUP_ID=

# Legacy / optional. iiko Cloud API v2 token does not use this value.
IIKO_API_LOGIN=

IIKO_WEBHOOK_TOKEN=your_webhook_token_here

# Public URL of the current tenant deployment.
# For the first pilot this points to Kafema Kurort.
NEXT_PUBLIC_APP_URL=https://kafema-kurort.vercel.app
